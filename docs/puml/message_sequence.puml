@startuml WebUi_Connection_Flow
title Browser UI flow: open connection, exchange bytes, stop

skinparam participantPadding 15

actor User
participant "Browser UI\n(webui)" as UI
participant "Static server\n(putty_rs_web)" as HTTP
participant "gRPC service\n(putty_grpc_server)" as GRPC
participant "ConnectionManager" as CM
participant "I/O task" as IO
participant "Transport\n(Serial / SSH)" as TR
participant "Remote endpoint" as REMOTE

== Load application ==
User -> HTTP : open http://127.0.0.1:8080
HTTP --> User : index.html + assets
User -> UI : interact with frontend

== Open connection ==
UI -> GRPC : CreateRemoteConnection(...)
GRPC -> CM : add_connection(id, conn)
CM -> IO : spawn per-connection task
IO -> TR : connect()
GRPC --> UI : ConnectionId

== Exchange bytes ==
UI -> GRPC : Write(id, data)
GRPC -> CM : write_bytes(id, data)
CM -> IO : IoEvent::Write(data)
IO -> TR : write(data)
TR -> REMOTE : bytes

REMOTE --> TR : bytes
TR --> IO : read(buf)
IO -> CM : broadcast chunk
CM --> GRPC : subscriber receives chunk
GRPC --> UI : Read stream(ByteChunk)

== Stop ==
UI -> GRPC : Stop(id)
GRPC -> CM : stop_connection(id)
CM -> IO : IoEvent::Stop
IO -> TR : disconnect()
IO --> CM : task ends
GRPC --> UI : Empty

legend bottom
  The CLI follows the same core flow, but talks to ConnectionManager directly
  instead of going through the browser UI and gRPC service.
endlegend
@enduml
